# =====================================================================
# Build output (regenerated by `make`; never committed)
# =====================================================================
build/
bin/
*.o
*.a
*.so.tmp

# Wayland protocol code is generated into build/ by wayland-scanner,
# so it is already covered above. Noted here for the reader:
#   examples/03_virtual_screen/build/wlr-screencopy-*-protocol.*

# =====================================================================
# Runtime output from the samples
# =====================================================================
# Camera sample writes frame_000001.jpg ... into its working dir.
frame_*.jpg
frame_*.png
*.log

# =====================================================================
# Rendered demo media (working files; keep the committed asset in docs/)
# =====================================================================
/demo.mp4
/demo-social.mp4
/*.gif

# =====================================================================
# Vendor SDK — proprietary VITURE binaries, kept local, never committed.
# Obtain it from VITURE and unpack under sdk/ to build. lib/ is just
# convenience symlinks into sdk/, so it is ignored too.
# sdk/README.md is the one exception: it documents the expected layout.
# =====================================================================
sdk/*
!sdk/README.md
lib/

# =====================================================================
# Local, machine-specific tooling config (never shared)
# =====================================================================
.claude/settings.local.json

# =====================================================================
# Editor / IDE
# =====================================================================
*.swp
*.swo
*~
.vscode/
.idea/
*.code-workspace
compile_commands.json
.cache/

# =====================================================================
# OS cruft
# =====================================================================
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
